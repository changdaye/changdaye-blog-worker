---
const { title, description, href = '#', meta = '', cover, topic } = Astro.props;
---
<article class="card" style="overflow: hidden; display: grid; gap: 0;">
  {cover && <img src={cover} alt={title} style="aspect-ratio: 16 / 9; object-fit: cover; width: 100%;" />}
  <div style="padding: 22px; display: grid; gap: 10px;">
    <div style="display:flex; justify-content:space-between; gap:12px; align-items:center; flex-wrap:wrap;">
      <div class="muted" style="font-size: 13px;">{meta}</div>
      {topic && <span class="tag">{topic}</span>}
    </div>
    <h2 style="margin: 0; font-size: 24px;"><a href={href}>{title}</a></h2>
    <p class="muted" style="margin: 0; line-height: 1.8;">{description}</p>
  </div>
</article>
