---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404" description="页面未找到">
  <main>
    <section class="section card" style="padding: 40px; text-align: center; display: grid; gap: 14px;">
      <h1 style="margin: 0;">404</h1>
      <p class="muted" style="margin: 0;">你访问的页面不存在，返回首页继续阅读。</p>
      <p style="margin: 0;"><a class="tag" href="/">返回首页</a></p>
    </section>
  </main>
</BaseLayout>
